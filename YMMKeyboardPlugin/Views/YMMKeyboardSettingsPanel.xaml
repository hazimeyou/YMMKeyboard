<UserControl x:Class="YMMKeyboardPlugin.Views.YMMKeyboardSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:c="clr-namespace:YukkuriMovieMaker.Controls;assembly=YukkuriMovieMaker.Controls"
             xmlns:theme="clr-namespace:YukkuriMovieMaker.Theme;assembly=YukkuriMovieMaker.Plugin"
             mc:Ignorable="d"
             MinHeight="320"
             MinWidth="480">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="繧ｭ繝ｼ繝懊・繝峨・繝ｩ繧ｰ繧､繝ｳ險ｭ螳・
                       FontSize="16"
                       FontWeight="Bold"/>
            <TextBlock Margin="0,6,0,0"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       Text="謗･邯壹☆繧気OM繝昴・繝医∬ｵｷ蜍墓凾縺ｮ閾ｪ蜍墓磁邯壹ゞI繧ｭ繝ｼ繝懊・繝峨→螳滓ｩ溘・蜑ｲ繧雁ｽ薙※繧偵％縺薙°繧芽ｨｭ螳壹〒縺阪∪縺吶・/>
        </StackPanel>

        <Border Grid.Row="2"
                Padding="10"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="COM繝昴・繝・ FontWeight="Bold"/>
                    <ComboBox x:Name="PortComboBox"
                              Margin="0,8,0,0"
                              MinWidth="180"
                              SelectionChanged="PortComboBox_OnSelectionChanged"/>
                    <TextBlock x:Name="PortStatusTextBlock"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Margin="10,20,0,0"
                        Padding="10,5"
                        VerticalAlignment="Top"
                        Content="蜀崎ｪｭ縺ｿ霎ｼ縺ｿ"
                        Click="ReloadPorts_OnClick"/>

                <Button Grid.Column="2"
                        Margin="10,20,0,0"
                        Padding="10,5"
                        VerticalAlignment="Top"
                        Content="謗･邯・
                        Click="Connect_OnClick"/>

                <Button Grid.Column="3"
                        Margin="10,20,0,0"
                        Padding="10,5"
                        VerticalAlignment="Top"
                        Content="謗･邯夊ｧ｣髯､"
                        Click="Disconnect_OnClick"/>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Padding="10"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="襍ｷ蜍墓凾縺ｫ謗･邯壹☆繧気OM繝昴・繝・ FontWeight="Bold"/>
                    <ListBox x:Name="StartupPortsListBox"
                             Margin="0,8,0,0"
                             MinHeight="80"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="10,20,0,0">
                    <Button Padding="10,5"
                            Content="霑ｽ蜉"
                            Click="AddStartupPort_OnClick"/>
                    <Button Margin="0,8,0,0"
                            Padding="10,5"
                            Content="蜑企勁"
                            Click="RemoveStartupPort_OnClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="5"
                Margin="0,12,0,0"
                Padding="10"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Text="繧ｭ繝ｼ繝懊・繝峨・蜑ｲ繧雁ｽ薙※" FontWeight="Bold"/>
                <TextBlock Margin="0,8,0,0"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Text="蜑ｲ繧雁ｽ薙※邱ｨ髮・・蛻･繧ｦ繧｣繝ｳ繝峨え縺ｧ髢九″縺ｾ縺吶６I繧ｭ繝ｼ繝懊・繝臥畑縺ｨ螳滓ｩ欟ID逕ｨ繧貞・繧頑崛縺医※邱ｨ髮・〒縺阪∪縺吶・/>
                <Button Margin="0,10,0,0"
                        Width="140"
                        Padding="10,5"
                        HorizontalAlignment="Left"
                        Content="蜑ｲ繧雁ｽ薙※繧帝幕縺・
                        Click="OpenMappingWindow_OnClick"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

