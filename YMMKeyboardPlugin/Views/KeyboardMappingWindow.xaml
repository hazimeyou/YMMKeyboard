<Window x:Class="YMMKeyboardPlugin.Views.KeyboardMappingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:c="clr-namespace:YukkuriMovieMaker.Controls;assembly=YukkuriMovieMaker.Controls"
        xmlns:theme="clr-namespace:YukkuriMovieMaker.Theme;assembly=YukkuriMovieMaker.Plugin"
        mc:Ignorable="d"
        Title="キー割り当て"
        Height="700"
        Width="940"
        MinHeight="560"
        MinWidth="820">
    <Window.Resources>
        <Style x:Key="KeyboardButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="78"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlDarkDarkBrushKey}}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="キー割り当て"
                       FontSize="18"
                       FontWeight="Bold"/>
            <TextBlock Margin="0,4,0,0"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       Text="左のキーボードからキーを選ぶと、右側でそのキーや複数キーの動作を編集できます。"/>
        </StackPanel>

        <Border Grid.Row="2"
                Padding="10"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="対象" FontWeight="Bold"/>
                    <ComboBox x:Name="ScopeComboBox"
                              Margin="0,8,0,0"
                              IsEditable="True"
                              IsTextSearchEnabled="False"
                              MinWidth="220"/>
                    <CheckBox x:Name="ComboModeCheckBox"
                              Margin="0,10,0,0"
                              Content="複数キー編集モード"
                              Checked="ComboModeCheckBox_OnChanged"
                              Unchecked="ComboModeCheckBox_OnChanged"/>
                    <TextBlock x:Name="StatusTextBlock"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Margin="10,20,0,0"
                        Padding="10,5"
                        VerticalAlignment="Top"
                        Content="対象を開く"
                        Click="OpenScope_OnClick"/>
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="12"
                    Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="キーボード配置"
                                   FontSize="14"
                                   FontWeight="Bold"/>
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   Text="単独キーはそのまま選択、複数キー編集モードでは押したい組み合わせを順に選んでください。"/>
                    </StackPanel>

                    <Grid Grid.Row="2" x:Name="KeyboardSurfaceGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <UniformGrid Grid.Row="0" Columns="6">
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW01" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW02" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW03" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW04" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW05" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW06" Click="SwitchButton_OnClick"/>

                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW07" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW08" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW09" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW10" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW11" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW12" Click="SwitchButton_OnClick"/>

                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW13" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW14" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW15" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW16" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW17" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW18" Click="SwitchButton_OnClick"/>

                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW19" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW20" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW21" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW22" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW23" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW24" Click="SwitchButton_OnClick"/>

                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW25" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW26" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW27" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW28" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW29" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW30" Click="SwitchButton_OnClick"/>
                        </UniformGrid>

                        <Border Grid.Row="2"
                                Padding="10"
                                Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <StackPanel>
                                <TextBlock Text="ロータリー"
                                           FontSize="14"
                                           FontWeight="Bold"/>
                                <TextBlock Margin="0,4,0,8"
                                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                           Text="回転と押し込みも横並びで設定できます。"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW36" Click="SwitchButton_OnClick" Width="96"/>
                                    <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW35" Click="SwitchButton_OnClick" Width="96"/>
                                    <Button Style="{StaticResource KeyboardButtonStyle}" Tag="SW37" Click="SwitchButton_OnClick" Width="96"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="12"
                    Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="選択中のキー"
                                   FontSize="14"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="SelectedSwitchTextBlock"
                                   Margin="0,8,0,0"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Text="SW01"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="動作" FontWeight="Bold"/>
                        <ComboBox x:Name="ActionComboBox"
                                  Margin="0,8,0,0"
                                  SelectionChanged="ActionComboBox_OnSelectionChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4">
                        <TextBlock Text="パラメータ" FontWeight="Bold"/>
                        <TextBox x:Name="ParameterTextBox"
                                 Margin="0,8,0,0"
                                 TextChanged="ParameterTextBox_OnTextChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Row="6">
                        <TextBlock Text="説明" FontWeight="Bold"/>
                        <TextBlock x:Name="SelectionHintTextBlock"
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   TextWrapping="Wrap"
                                   Text="キーを選ぶとここに設定内容が表示されます。"/>
                    </StackPanel>

                    <Button Grid.Row="8"
                            Padding="10,6"
                            Content="この設定をテスト実行"
                            Click="TestSelectedButton_OnClick"/>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="104"
                    Padding="10,5"
                    Content="閉じる"
                    Click="CloseButton_OnClick"/>
        </StackPanel>
    </Grid>
</Window>

