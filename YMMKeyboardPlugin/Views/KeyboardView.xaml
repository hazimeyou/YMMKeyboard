<UserControl
    x:Class="YMMKeyboardPlugin.Views.KeyboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:c="clr-namespace:YukkuriMovieMaker.Controls;assembly=YukkuriMovieMaker.Controls"
    xmlns:theme="clr-namespace:YukkuriMovieMaker.Theme;assembly=YukkuriMovieMaker.Plugin"
    mc:Ignorable="d"
    MinWidth="680"
    MinHeight="280">

    <UserControl.Resources>
        <Style x:Key="KeyButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlDarkDarkBrushKey}}"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock
                Text="YMM4繧ｭ繝ｼ繝懊・繝・
                FontWeight="Bold"
                FontSize="13"/>
            <TextBlock
                Margin="0,3,0,0"
                Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                Text="蜊倡峡繧ｯ繝ｪ繝・け縺ｯ縺昴・繧ｭ繝ｼ繧貞ｮ溯｡後＠縺ｾ縺吶り､・焚繧ｭ繝ｼ螳溯｡後Δ繝ｼ繝峨〒縺ｯ縲√く繝ｼ繧帝∈繧薙〒縺九ｉ縺ｾ縺ｨ繧√※螳溯｡後〒縺阪∪縺吶・/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="196"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" x:Name="KeyboardSurfaceGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <UniformGrid Grid.Row="0" Columns="6">
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW01" Tag="SW01" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW02" Tag="SW02" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW03" Tag="SW03" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW04" Tag="SW04" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW05" Tag="SW05" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW06" Tag="SW06" Click="SwitchButton_OnClick"/>

                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW07" Tag="SW07" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW08" Tag="SW08" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW09" Tag="SW09" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW10" Tag="SW10" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW11" Tag="SW11" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW12" Tag="SW12" Click="SwitchButton_OnClick"/>

                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW13" Tag="SW13" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW14" Tag="SW14" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW15" Tag="SW15" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW16" Tag="SW16" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW17" Tag="SW17" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW18" Tag="SW18" Click="SwitchButton_OnClick"/>

                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW19" Tag="SW19" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW20" Tag="SW20" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW21" Tag="SW21" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW22" Tag="SW22" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW23" Tag="SW23" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW24" Tag="SW24" Click="SwitchButton_OnClick"/>

                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW25" Tag="SW25" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW26" Tag="SW26" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW27" Tag="SW27" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW28" Tag="SW28" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW29" Tag="SW29" Click="SwitchButton_OnClick"/>
                    <Button Style="{StaticResource KeyButtonStyle}" Content="SW30" Tag="SW30" Click="SwitchButton_OnClick"/>
                </UniformGrid>

                <Border Grid.Row="2"
                        Padding="8"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}">
                    <StackPanel>
                        <TextBlock Text="Rotary" FontWeight="Bold" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Button Style="{StaticResource KeyButtonStyle}" Content="Left" Tag="SW36" Width="62" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyButtonStyle}" Content="Push" Tag="SW35" Width="62" Click="SwitchButton_OnClick"/>
                            <Button Style="{StaticResource KeyButtonStyle}" Content="Right" Tag="SW37" Width="62" Click="SwitchButton_OnClick"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Column="2"
                    Padding="10"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                    Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                <StackPanel>
                    <CheckBox x:Name="ComboModeCheckBox"
                              Content="隍・焚繧ｭ繝ｼ螳溯｡後Δ繝ｼ繝・
                              Checked="ComboModeCheckBox_OnChanged"
                              Unchecked="ComboModeCheckBox_OnChanged"/>
                    <TextBlock Margin="0,8,0,0"
                               FontWeight="Bold"
                               Text="驕ｸ謚樔ｸｭ"/>
                    <TextBlock x:Name="SelectedKeysTextBlock"
                               Margin="0,3,0,0"
                               TextWrapping="Wrap"
                               Text="縺ｪ縺・/>
                    <TextBlock Margin="0,10,0,0"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               TextWrapping="Wrap"
                               Text="縺薙・繝｢繝ｼ繝峨〒縺ｯ繧ｭ繝ｼ繧偵け繝ｪ繝・け縺励※驕ｸ謚槭＠縺ｾ縺吶・縺､莉･荳企∈繧薙□繧峨∪縺ｨ繧√※螳溯｡後〒縺阪∪縺吶・/>
                    <Button Margin="0,14,0,0"
                            Padding="8,5"
                            Content="隍・焚繧ｭ繝ｼ繧貞ｮ溯｡・
                            Click="ExecuteCombinationButton_OnClick"/>
                    <Button Margin="0,8,0,0"
                            Padding="8,5"
                            Content="驕ｸ謚槭ｒ繧ｯ繝ｪ繧｢"
                            Click="ClearSelectionButton_OnClick"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

