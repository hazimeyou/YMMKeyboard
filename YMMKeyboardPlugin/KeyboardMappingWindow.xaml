<Window x:Class="YMMKeyboardPlugin.KeyboardMappingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="キーボード割り当て"
        Height="720"
        Width="760"
        MinHeight="560"
        MinWidth="680">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="キーボードの割り当て"
                       FontSize="18"
                       FontWeight="Bold"/>
            <TextBlock Margin="0,6,0,0"
                       Foreground="#666"
                       Text="UIキーボード用と実機UID用の割り当てを別々に設定できます。"/>
        </StackPanel>

        <Border Grid.Row="2"
                Padding="12"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="対象" FontWeight="Bold"/>
                    <ComboBox x:Name="ScopeComboBox"
                              Margin="0,8,0,0"
                              IsEditable="True"
                              IsTextSearchEnabled="False"
                              MinWidth="260"/>
                    <TextBlock x:Name="StatusTextBlock"
                               Margin="0,8,0,0"
                               Foreground="#666"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Margin="12,24,0,0"
                        Padding="12,6"
                        VerticalAlignment="Top"
                        Content="対象を開く"
                        Click="OpenScope_OnClick"/>
            </Grid>
        </Border>

        <DataGrid Grid.Row="4"
                  x:Name="AssignmentsGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  IsReadOnly="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="スイッチ"
                                    Binding="{Binding SwitchName}"
                                    IsReadOnly="True"
                                    Width="120"/>
                <DataGridTemplateColumn Header="動作" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding SelectedActionName}" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding AvailableActions}"
                                      SelectedItem="{Binding SelectedActionName, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="パラメータ"
                                    Binding="{Binding Parameter, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*"/>
                <DataGridTemplateColumn Header="テスト" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="実行"
                                    Padding="8,2"
                                    Click="TestButton_OnClick"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="120"
                    Padding="12,6"
                    Content="閉じる"
                    Click="CloseButton_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
