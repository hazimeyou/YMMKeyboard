<UserControl x:Class="YMMKeyboardPlugin.Views.YMMKeyboardSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:c="clr-namespace:YukkuriMovieMaker.Controls;assembly=YukkuriMovieMaker.Controls"
             xmlns:theme="clr-namespace:YukkuriMovieMaker.Theme;assembly=YukkuriMovieMaker.Plugin"
             mc:Ignorable="d"
             MinHeight="280"
             MinWidth="430">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="キーボードプラグイン設定"
                       FontSize="14"
                       FontWeight="Bold"/>
            <TextBlock Margin="0,4,0,0"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       Text="USB HID を正式経路として使います。HID フィルタ、ロータリー感度、ログ設定を調整できます。"/>
        </StackPanel>

        <Border Grid.Row="2"
                Padding="8"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="USB HID / 診断" FontWeight="Bold"/>
                    <TextBlock Margin="0,6,0,0"
                               Text="VID / PID と製品名・メーカーのフィルタを調整します。"
                               TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock VerticalAlignment="Center" Text="VID(16進):"/>
                        <TextBox x:Name="HidVendorIdTextBox" Width="72" Margin="6,0,0,0"/>
                        <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" Text="PID(16進):"/>
                        <TextBox x:Name="HidProductIdTextBox" Width="72" Margin="6,0,0,0"/>
                        <Button Margin="8,0,0,0"
                                Padding="8,2"
                                Content="適用"
                                Click="ApplyHidFilter_OnClick"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock VerticalAlignment="Center" Text="製品名:"/>
                        <TextBox x:Name="HidProductNameFilterTextBox" Width="130" Margin="6,0,0,0"/>
                        <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" Text="メーカー:"/>
                        <TextBox x:Name="HidManufacturerFilterTextBox" Width="130" Margin="6,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock VerticalAlignment="Center" Text="ロータリー感度:"/>
                        <ComboBox x:Name="RotarySensitivityComboBox"
                                  Margin="6,0,0,0"
                                  Width="120"
                                  SelectionChanged="RotarySensitivityComboBox_OnSelectionChanged">
                            <ComboBoxItem Content="高: 1" Tag="1"/>
                            <ComboBoxItem Content="標準: 2" Tag="2"/>
                            <ComboBoxItem Content="低: 3" Tag="3"/>
                            <ComboBoxItem Content="かなり低: 4" Tag="4"/>
                        </ComboBox>
                    </StackPanel>

                    <TextBlock Margin="0,4,0,0"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               Text="ロータリー入力を何回受け取ったら1回の操作として扱うかを指定します。値を大きくすると反応が鈍くなり、誤入力が減ります。"
                               TextWrapping="Wrap"/>

                    <TextBlock x:Name="PortStatusTextBlock"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="RuntimeLoggingCheckBox"
                                  Content="ログを有効化"
                                  VerticalAlignment="Center"
                                  Checked="RuntimeLoggingCheckBox_OnChanged"
                                  Unchecked="RuntimeLoggingCheckBox_OnChanged"/>
                        <Button Margin="12,0,0,0"
                                Padding="8,2"
                                Content="ログフォルダーを開く"
                                Click="OpenLogFolder_OnClick"/>
                        <Button Margin="8,0,0,0"
                                Padding="8,2"
                                Content="ログをクリア"
                                Click="ClearLog_OnClick"/>
                    </StackPanel>
                    <Button Margin="0,10,0,0"
                            Padding="8,4"
                            HorizontalAlignment="Left"
                            Content="HID診断"
                            Click="HidProbe_OnClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Margin="0,10,0,0"
                Padding="8"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Text="キー割り当て" FontWeight="Bold"/>
                <TextBlock Margin="0,6,0,0"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Text="UIキーボードと実機UIDごとの割り当てを編集できます。"/>
                <Button Margin="0,8,0,0"
                        Width="124"
                        Padding="8,4"
                        HorizontalAlignment="Left"
                        Content="割り当てを開く"
                        Click="OpenMappingWindow_OnClick"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
